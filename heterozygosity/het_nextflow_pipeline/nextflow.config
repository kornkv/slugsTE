// =============================================================================
// Nextflow config for HiFi heterozygosity pipeline
// =============================================================================

docker {
    enabled    = true
    // Run containers as the invoking user so output files aren't owned by root
    runOptions = '-u $(id -u):$(id -g)'
}

process {
    container = 'hifi-het:latest'
    // Default resource hints; per-process overrides live in main.nf
    cpus   = 4
    memory = '8 GB'
    errorStrategy = 'retry'
    maxRetries    = 1
}

// Show meaningful timeline / report / DAG without extra flags
timeline { enabled = true; file = "${params.outdir ?: 'results'}/pipeline_info/timeline.html"; overwrite = true }
report   { enabled = true; file = "${params.outdir ?: 'results'}/pipeline_info/report.html";   overwrite = true }
trace    { enabled = true; file = "${params.outdir ?: 'results'}/pipeline_info/trace.tsv";     overwrite = true }
dag      { enabled = true; file = "${params.outdir ?: 'results'}/pipeline_info/dag.html";      overwrite = true }

profiles {
    // Local execution, one sample at a time on a single host
    standard {
        process.executor = 'local'
    }

    // Bigger host: let Nextflow run multiple samples in parallel
    // Use with: nextflow run main.nf -profile parallel
    parallel {
        process.executor = 'local'
        executor {
            cpus   = Runtime.runtime.availableProcessors()
            memory = '90 GB'
        }
    }
}
