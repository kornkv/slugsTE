// Per-process resource overrides tuned for a 32-core / ~60 GB host.
// Pass with: -c maxcpu.config
//
// Sizing rationale:
//   MAP_HIFI       — 24 cpus. minimap2 scales to ~24 threads; samtools sort
//                    in the pipe adds cpus/4 = 6 more threads = 30 on 32 cores
//                    (avoids oversubscription). 48 GB covers index + sort buffers.
//   CALL_VARIANTS  — 8 cpus. bcftools mpileup pileup work is single-threaded;
//                    --threads only parallelises BGZF compression. >8 is waste.
//   INDEX_REF      — 2 cpus.  samtools faidx is single-threaded, IO-bound.
//   FILTER_HET     — 4 cpus.  bcftools view, fast.
//   COUNT_HET      — 4 cpus.  awk + bedtools intersect, IO-bound.
process {
    withName: INDEX_REF     { cpus = 2;  memory = '4 GB'  }
    withName: MAP_HIFI      { cpus = 24; memory = '48 GB' }
    withName: CALL_VARIANTS { cpus = 8;  memory = '8 GB'  }
    withName: FILTER_HET    { cpus = 4;  memory = '4 GB'  }
    withName: COUNT_HET     { cpus = 4;  memory = '4 GB'  }
}
